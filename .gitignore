# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage*
htmlcov/

# Node
node_modules/
frontend/dist/

# Bulk data. Raw FITS caches are re-fetchable from NASA (MAST / s3://stpubdata)
# and stay local-only; everything else under data/ and the promoted model run
# are DVC-tracked — git carries the .dvc pointers (and DVC's per-directory
# .gitignore files), R2 carries the bytes.
data/raw/
data/raw_kepler/
data/interim/
models/cv/*
!models/cv/*.dvc
mlruns/
outputs/
multirun/

# DVC internals (pointers *are* committed; cache is not)
.dvc/cache/
.dvc/tmp/

# Environments & editors
.env
.envrc
.DS_Store
.idea/
.vscode/

# MLflow local tracking store
mlflow.db

# Training-run outputs (plots, tier tables) — MLflow/DVC territory
results/
.claude/
